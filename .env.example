PORT=5000
MONGODB_URI=mongodb://localhost:27017/jolshaa
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Cloudinary (REQUIRED for image/video uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Payment Gateway - Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Payment Gateway - SSLCommerz (sandbox for testing)
# Get free sandbox credentials at: https://developer.sslcommerz.com/
# 1. Sign up at https://developer.sslcommerz.com/
# 2. Create a store from the dashboard
# 3. Use the sandbox store_id and store_pass below
# 4. Sandbox accepts test cards: 4111111111111111 (Visa), 5500000000000004 (MasterCard)
# 5. bKash test: use sandbox phone numbers provided in SSLCommerz docs
# 6. Set SSLCOMMERZ_IS_SANDBOX=true for testing, false for production
SSLCOMMERZ_STORE_ID=your_sandbox_store_id
SSLCOMMERZ_STORE_PASS=your_sandbox_store_pass
SSLCOMMERZ_IS_SANDBOX=true

# Email - Nodemailer (Gmail SMTP)
